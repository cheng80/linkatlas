{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://linkatlas.local/schemas/document-analysis.schema.json",
  "title": "DocumentAnalysis",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "language",
    "contentType",
    "headline",
    "abstract",
    "keyPoints",
    "actionItems",
    "caveats",
    "topics",
    "entities",
    "claims"
  ],
  "properties": {
    "language": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16
    },
    "contentType": {
      "type": "string",
      "enum": [
        "tutorial",
        "reference",
        "news",
        "opinion",
        "research",
        "documentation",
        "announcement",
        "discussion",
        "other"
      ]
    },
    "headline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 240
    },
    "abstract": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4000
    },
    "keyPoints": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/evidencedText" }
    },
    "actionItems": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/evidencedText" }
    },
    "caveats": {
      "type": "array",
      "maxItems": 8,
      "items": { "$ref": "#/$defs/evidencedText" }
    },
    "topics": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "description", "confidence", "evidenceBlockIds"],
        "properties": {
          "label": { "type": "string", "minLength": 1, "maxLength": 80 },
          "description": { "type": "string", "maxLength": 300 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceBlockIds": {
            "type": "array",
            "maxItems": 12,
            "items": { "type": "string", "pattern": "^b[0-9]{4,}$" }
          }
        }
      }
    },
    "entities": {
      "type": "array",
      "maxItems": 40,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "type", "aliases", "confidence", "evidenceBlockIds"],
        "properties": {
          "name": { "type": "string", "minLength": 1, "maxLength": 160 },
          "type": {
            "type": "string",
            "enum": [
              "PERSON",
              "ORGANIZATION",
              "PRODUCT",
              "TECHNOLOGY",
              "PROJECT",
              "PLACE",
              "EVENT",
              "CONCEPT",
              "STANDARD",
              "VERSION",
              "OTHER"
            ]
          },
          "aliases": {
            "type": "array",
            "maxItems": 8,
            "items": { "type": "string", "maxLength": 160 }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceBlockIds": {
            "type": "array",
            "maxItems": 12,
            "items": { "type": "string", "pattern": "^b[0-9]{4,}$" }
          }
        }
      }
    },
    "claims": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["text", "stance", "confidence", "evidenceBlockIds"],
        "properties": {
          "text": { "type": "string", "minLength": 1, "maxLength": 600 },
          "stance": {
            "type": "string",
            "enum": ["assertion", "recommendation", "warning", "hypothesis", "opinion"]
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidenceBlockIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 12,
            "items": { "type": "string", "pattern": "^b[0-9]{4,}$" }
          }
        }
      }
    }
  },
  "$defs": {
    "evidencedText": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "evidenceBlockIds"],
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 800 },
        "evidenceBlockIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "items": { "type": "string", "pattern": "^b[0-9]{4,}$" }
        }
      }
    }
  }
}
