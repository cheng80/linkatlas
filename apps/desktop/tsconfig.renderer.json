{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "tsBuildInfoFile": "dist/.tsbuildinfo/renderer.tsbuildinfo",
    "types": ["vite/client", "vitest/globals"]
