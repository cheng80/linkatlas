{
  "name": "@linkatlas/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/main.js",
  "scripts": {
    "build": "pnpm clean && pnpm build:main && pnpm build:preload && pnpm build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "dev": "vite --host 127.0.0.1",
    "dist:mac": "pnpm build && electron-builder --mac dmg --config electron-builder.yml",
    "test": "vitest --root ../.. run apps/desktop/src"
  },
  "dependencies": {
    "@linkatlas/analysis": "workspace:*",
    "@linkatlas/contracts": "workspace:*",
    "@linkatlas/domain": "workspace:*",
    "@linkatlas/ingestion": "workspace:*",
    "@linkatlas/llm": "workspace:*",
    "@linkatlas/search": "workspace:*",
    "@linkatlas/storage": "workspace:*",
    "fflate": "^0.8.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3"
  }
}
