{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/main",
    "rootDir": "src/main",
    "tsBuildInfoFile": "dist/.tsbuildinfo/main.tsbuildinfo",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/main/**/*.ts"],
  "exclude": ["src/**/*.test.ts"]
}
